# AllTogether – Environment Variables (EXAMPLE)
# ─────────────────────────────────────────────────────────────
# This file is safe to commit. It documents required variables.
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found at: supabase.com → project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Anthropic (Claude API) ────────────────────────────────────
# Found at: console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-your_claude_api_key_here

# ── Google Places API ─────────────────────────────────────────
# Found at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=AIzaSy-your_google_places_key_here

# ── Climatiq ─────────────────────────────────────────────────
# Found at: climatiq.io → Dashboard → API Keys
CLIMATIQ_API_KEY=your_climatiq_api_key_here
